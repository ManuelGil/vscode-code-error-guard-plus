{
	"name": "vscode-code-error-guard-plus",
	"displayName": "CodeErrorGuard+",
	"description": "Insert, review, and remove generated try/catch structures across multiple languages while preserving ownership of your code.",
	"version": "1.0.1",
	"icon": "icon.png",
	"license": "MIT",
	"publisher": "imgildev",
	"author": {
		"name": "Manuel Gil",
		"email": "support@imgil.dev",
		"url": "https://imgil.dev/"
	},
	"sponsor": {
		"url": "https://github.com/sponsors/ManuelGil"
	},
	"packageManager": "pnpm@10.0.0",
	"engines": {
		"vscode": "^1.102.0",
		"node": ">=22.15.1"
	},
	"categories": [
		"Other"
	],
	"keywords": [
		"try catch",
		"try/catch",
		"exception handling",
		"error handling",
		"code templates",
		"code cleanup",
		"multi-language",
		"javascript",
		"typescript",
		"python"
	],
	"homepage": "https://github.com/ManuelGil/vscode-code-error-guard-plus",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/ManuelGil/vscode-code-error-guard-plus.git"
	},
	"bugs": {
		"url": "https://github.com/ManuelGil/vscode-code-error-guard-plus/issues"
	},
	"activationEvents": [
		"onStartupFinished"
	],
	"files": [
		"out",
		"package*.json",
		"README.md",
		"LICENSE",
		"icon.png",
		"schemas",
		"l10n"
	],
	"main": "./out/extension.js",
	"l10n": "./l10n",
	"contributes": {
		"configuration": {
			"type": "object",
			"title": "CodeErrorGuard+ Try/Catch Configuration",
			"properties": {
				"codeErrorGuardPlus.enable": {
					"type": "boolean",
					"default": true,
					"scope": "resource",
					"description": "%codeErrorGuardPlus.enable.description%"
				},
				"codeErrorGuardPlus.defaultLanguage": {
					"type": "string",
					"default": "javascript",
					"enum": [
						"javascript",
						"typescript",
						"java",
						"csharp",
						"php",
						"dart",
						"python",
						"cpp",
						"ruby",
						"go"
					],
					"enumDescriptions": [
						"JavaScript",
						"TypeScript",
						"Java",
						"C#",
						"PHP",
						"Dart",
						"Python",
						"C++",
						"Ruby",
						"Go"
					],
					"scope": "resource",
					"description": "%codeErrorGuardPlus.defaultLanguage.description%"
				},
				"codeErrorGuardPlus.errorVariableName": {
					"type": "string",
					"default": "error",
					"scope": "resource",
					"description": "Default variable name for errors captured inside catch blocks."
				},
				"codeErrorGuardPlus.catchBlockContent": {
					"type": "string",
					"default": "// TODO: handle error",
					"scope": "resource",
					"description": "Default placeholder statement inserted at the top of each generated catch block."
				},
				"codeErrorGuardPlus.catchFollowUpStatement": {
					"type": "string",
					"default": "// TODO: surface or rethrow error",
					"scope": "resource",
					"description": "Default neutral follow-up placeholder appended inside generated catch blocks."
				},
				"codeErrorGuardPlus.customTemplates": {
					"type": "array",
					"items": {
						"type": "object",
						"required": [
							"language",
							"tryBlock",
							"catchBlock"
						],
						"properties": {
							"language": {
								"type": "string",
								"enum": [
									"javascript",
									"typescript",
									"java",
									"csharp",
									"php",
									"dart",
									"python",
									"cpp",
									"ruby",
									"go"
								],
								"enumDescriptions": [
									"JavaScript",
									"TypeScript",
									"Java",
									"C#",
									"PHP",
									"Dart",
									"Python",
									"C++",
									"Ruby",
									"Go"
								],
								"description": "%codeErrorGuardPlus.customTemplates.language.description%"
							},
							"tryBlock": {
								"type": "array",
								"description": "Each entry represents a line inserted before the selected code. Tokens like {{indent}}, {{indentUnit}} or {{errorVar}} can be used.",
								"items": {
									"type": "string"
								}
							},
							"catchBlock": {
								"type": "array",
								"description": "Each entry represents a line inserted after the selected code. Tokens like {{catchContent}} or {{followUpStatement}} can be used.",
								"items": {
									"type": "string"
								}
							}
						}
					},
					"default": [],
					"scope": "resource",
					"description": "%codeErrorGuardPlus.customTemplates.description%"
				}
			}
		},
		"commands": [
			{
				"command": "codeErrorGuardPlus.insertTryCatch",
				"title": "%codeErrorGuardPlus.command.insertTryCatch.title%",
				"category": "CodeErrorGuard+",
				"icon": "$(insert)"
			},
			{
				"command": "codeErrorGuardPlus.removeGeneratedTryCatch",
				"title": "%codeErrorGuardPlus.command.removeGeneratedTryCatch.title%",
				"category": "CodeErrorGuard+",
				"icon": "$(combine)"
			},
			{
				"command": "codeErrorGuardPlus.removeGeneratedTryCatchFile",
				"title": "%codeErrorGuardPlus.command.removeGeneratedTryCatchFile.title%",
				"category": "CodeErrorGuard+",
				"icon": "$(combine)"
			},
			{
				"command": "codeErrorGuardPlus.changeWorkspace",
				"title": "%codeErrorGuardPlus.command.changeWorkspace.title%",
				"category": "CodeErrorGuard+",
				"icon": "$(folder-opened)"
			},
			{
				"command": "codeErrorGuardPlus.listTryCatchView.openContainingFolder",
				"title": "%codeErrorGuardPlus.listTryCatchView.openContainingFolder.title%",
				"category": "CodeErrorGuard+"
			},
			{
				"command": "codeErrorGuardPlus.listTryCatchView.revealFile",
				"title": "%codeErrorGuardPlus.listTryCatchView.revealFile.title%",
				"category": "CodeErrorGuard+"
			},
			{
				"command": "codeErrorGuardPlus.listTryCatchView.copyPath",
				"title": "%codeErrorGuardPlus.listTryCatchView.copyPath.title%",
				"category": "CodeErrorGuard+"
			},
			{
				"command": "codeErrorGuardPlus.listTryCatchView.gotoLineFromNode",
				"title": "%codeErrorGuardPlus.listTryCatchView.gotoLineFromNode.title%",
				"category": "CodeErrorGuard+"
			},
			{
				"command": "codeErrorGuardPlus.listTryCatchView.copyLogText",
				"title": "%codeErrorGuardPlus.listTryCatchView.copyLogText.title%",
				"category": "CodeErrorGuard+"
			},
			{
				"command": "codeErrorGuardPlus.listTryCatchView.refreshList",
				"title": "%codeErrorGuardPlus.listTryCatchView.refreshList.title%",
				"category": "CodeErrorGuard+",
				"icon": "$(refresh)"
			}
		],
		"keybindings": [
			{
				"key": "ctrl+alt+t",
				"mac": "cmd+alt+t",
				"command": "codeErrorGuardPlus.insertTryCatch",
				"when": "editorTextFocus",
				"description": "Insert a try/catch block at the cursor"
			},
			{
				"key": "ctrl+alt+shift+t",
				"mac": "cmd+alt+shift+t",
				"command": "codeErrorGuardPlus.removeGeneratedTryCatch",
				"when": "editorTextFocus",
				"description": "Remove a generated try/catch block"
			}
		],
		"submenus": [
			{
				"id": "codeErrorGuardPlus.editor.submenu",
				"label": "%codeErrorGuardPlus.menu.editor.label%"
			}
		],
		"menus": {
			"editor/title": [
				{
					"command": "codeErrorGuardPlus.insertTryCatch",
					"when": "editorTextFocus",
					"group": "navigation@-1"
				},
				{
					"command": "codeErrorGuardPlus.removeGeneratedTryCatch",
					"when": "editorTextFocus",
					"group": "navigation@-0.9"
				}
			],
			"view/title": [
				{
					"command": "codeErrorGuardPlus.listTryCatchView.refreshList",
					"when": "view == codeErrorGuardPlus.listTryCatchView",
					"group": "navigation@1"
				}
			],
			"view/item/context": [
				{
					"command": "codeErrorGuardPlus.listTryCatchView.revealFile",
					"when": "view == codeErrorGuardPlus.listTryCatchView && viewItem == file",
					"group": "navigation@1"
				},
				{
					"command": "codeErrorGuardPlus.listTryCatchView.openContainingFolder",
					"when": "view == codeErrorGuardPlus.listTryCatchView && viewItem == file",
					"group": "navigation@2"
				},
				{
					"command": "codeErrorGuardPlus.listTryCatchView.copyPath",
					"when": "view == codeErrorGuardPlus.listTryCatchView && viewItem == file",
					"group": "2_workspace@1"
				},
				{
					"command": "codeErrorGuardPlus.listTryCatchView.gotoLineFromNode",
					"when": "view == codeErrorGuardPlus.listTryCatchView && viewItem == log",
					"group": "navigation@1"
				},
				{
					"command": "codeErrorGuardPlus.listTryCatchView.copyLogText",
					"when": "view == codeErrorGuardPlus.listTryCatchView && viewItem == log",
					"group": "2_workspace@1"
				}
			],
			"editor/context": [
				{
					"submenu": "codeErrorGuardPlus.editor.submenu",
					"group": "1_modification"
				}
			],
			"codeErrorGuardPlus.editor.submenu": [
				{
					"command": "codeErrorGuardPlus.insertTryCatch",
					"when": "editorTextFocus"
				},
				{
					"command": "codeErrorGuardPlus.removeGeneratedTryCatch",
					"when": "editorTextFocus"
				},
				{
					"command": "codeErrorGuardPlus.removeGeneratedTryCatchFile",
					"when": "editorTextFocus"
				}
			],
			"commandPalette": [
				{
					"command": "codeErrorGuardPlus.insertTryCatch",
					"group": "1_primary@1"
				},
				{
					"command": "codeErrorGuardPlus.removeGeneratedTryCatch",
					"group": "1_primary@2"
				},
				{
					"command": "codeErrorGuardPlus.removeGeneratedTryCatchFile",
					"group": "1_primary@3"
				}
			]
		},
		"viewsWelcome": [
			{
				"view": "codeErrorGuardPlus.listTryCatchView",
				"contents": "%codeErrorGuardPlus.listTryCatchView.welcomeMessage%"
			}
		],
		"views": {
			"explorer": [
				{
					"id": "codeErrorGuardPlus.listTryCatchView",
					"name": "%codeErrorGuardPlus.listTryCatchView.title%",
					"visibility": "visible",
					"icon": "$(list-tree)"
				}
			]
		},
		"jsonValidation": [
			{
				"fileMatch": ".vscode/settings.json",
				"url": "./schemas/config.schema.json"
			}
		]
	},
	"scripts": {
		"vscode:prepublish": "pnpm compile",
		"typecheck": "tsc --noEmit -p ./",
		"compile": "pnpm typecheck && rimraf out && esbuild src/extension.ts --bundle --platform=node --target=node22 --format=cjs --external:vscode --outfile=out/extension.js",
		"watch": "tsc -watch -p ./",
		"pretest": "pnpm compile && tsc -p ./ && pnpm lint",
		"format": "biome format --write .",
		"lint": "biome lint .",
		"lint:fix": "biome lint --write .",
		"check": "biome check .",
		"check:fix": "biome check --write --unsafe .",
		"test": "vscode-test",
		"test:unit": "mocha -r ts-node/register src/**/*.test.ts",
		"l10n:check": "node scripts/check-l10n.js",
		"nls:check": "node scripts/check-nls.js",
		"prepare": "husky"
	},
	"devDependencies": {
		"@biomejs/biome": "1.9.4",
		"@commitlint/cli": "^19.8.1",
		"@commitlint/config-conventional": "^19.8.1",
		"@types/mocha": "^10.0.10",
		"@types/mustache": "^4.2.6",
		"@types/node": "^22.19.21",
		"@types/vscode": "^1.102.0",
		"@vscode/test-cli": "^0.0.12",
		"@vscode/test-electron": "^2.5.2",
		"esbuild": "^0.28.1",
		"husky": "^9.1.7",
		"lint-staged": "^15.5.2",
		"minimatch": "^10.2.5",
		"mocha": "^10.8.2",
		"rimraf": "^6.1.3",
		"tsx": "^4.22.4",
		"typescript": "^5.9.3",
		"vscode-test": "^1.6.1"
	},
	"dependencies": {
		"fast-glob": "^3.3.3",
		"ignore": "^5.3.2",
		"mustache": "^4.2.0",
		"p-limit": "^4.0.0",
		"vscode-marketplace-client": "^1.2.4"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild"
		],
		"overrides": {
			"diff@>=6.0.0 <8.0.3": ">=8.0.3",
			"@tootallnate/once@<2.0.1": ">=2.0.1",
			"serialize-javascript@>=5.0.0 <7.0.5": ">=7.0.5"
		}
	}
}
